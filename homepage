    <main>
        <div class="search-box">
    <div class="search-title">Advanced Search</div>
    <div class="search-inner">
      <select>
        <option>Title</option>
        <option>Author</option>
        <option>Collection Type</option>
        <option>ISBN</option>
      </select>
      <input type="text" placeholder="Type here">
      <div class="add-row">+</div>
      <div style="margin-top: 16px;">
        <div class="sort-label">Sort By</div>
        <select>
          <option>Newest</option>
          <option>Oldest</option>
          <option>Relevance</option>
        </select>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn-clear">CLEAR ALL</button>
      <a href="collectionpage.html">
      <button class="btn-search">SEARCH</button>
      </a>
    </div>
  </div>

  <!-- ACTION BUTTONS -->
  <div class="action-row">
    <div class="action-card">
      <div class="action-left">
        <div class="action-icon">
          <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>
        </div>
        <span class="action-label">Talk to Librarian</span>
      </div>
      <button class="btn-orange">TALK TO US</button>
    </div>
    <div class="action-card">
      <div class="action-left">
        <div class="action-icon">
          <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>
        </div>
        <span class="action-label">Room Reservation</span>
      </div>
      <a href="reservation.html">
      <button class="btn-orange">BOOK NOW</button>
      </a>
    </div>
  </div>

