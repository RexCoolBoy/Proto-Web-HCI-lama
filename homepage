<body>
    <nav class="navbar">
        <div class="logo">
            <h2>BINUS UNIVERSITY</h2>
        </div>

        <div class="homepagecari">
            &#128269;
            <input type="text" class="searchpunyahome" placeholder="Search collections: Text book, e-books, journals here">
        </div>

        <div>
            <button class="loginbtn">Login</button>
        </div>
    </nav>

    <nav class="navbarhome">
        <ul>
            <li><a href="#">Home</a></li>
            <li><a href="collectionpage.html">Collection</a></li>
            <li><a href="#">Recommendation</a></li>
            <li><a href="#">Talk To Us</a></li>
            <li><a href="#">Discussion Room</a></li>
            <li><a href="#">Support</a></li>
            <li><a href="#">More Library Service</a></li>
        </ul>
